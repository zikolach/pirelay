{
  "name": "pirelay",
  "version": "0.4.0",
  "description": "Pi package that pairs messenger chats to active Pi sessions for notifications and remote control.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zikolach/pirelay.git"
  },
  "bugs": {
    "url": "https://github.com/zikolach/pirelay/issues"
  },
  "homepage": "https://github.com/zikolach/pirelay#readme",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "pirelay",
    "telegram",
    "telegram-bot",
    "bot",
    "remote-control"
  ],
  "files": [
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "docs",
    "extensions",
    "skills"
  ],
  "scripts": {
    "build": "echo 'No build step required for JITI-loaded TypeScript'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm test",
    "openspec:validate": "openspec validate --changes --strict"
  },
  "pi": {
    "extensions": [
      "./extensions/relay/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "dependencies": {
    "@mariozechner/jiti": "^2.6.5",
    "discord.js": "^14.26.4",
    "grammy": "^1.42.0",
    "proper-lockfile": "^4.1.2",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.3.1",
    "@types/node": "^24.12.2",
    "@types/proper-lockfile": "^4.1.4",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
